generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  avatarUrl     String?
  role          String    @default("MEMBER") // "MEMBER", "LEADER", "ADMIN"
  churchId      String?
  church        Church?   @relation(fields: [churchId], references: [id])
  
  // Gamification
  xp            Int       @default(0)
  stars         Int       @default(0)
  level         Int       @default(1)
  streak        Int       @default(0)
  lastActiveAt  DateTime?

  // Relations
  groups        UserGroup[]
  attendances   Attendance[]
  prayerRequests PrayerRequest[]
  badges        UserBadge[]
  xpLogs        XPLog[]
  quizAttempts  QuizAttempt[]
  appointments  Appointment[]
  pushSubscriptions PushSubscription[]
  uploadedPhotos EventGalleryPhoto[]
  notifications Notification[]
  mentorshipQuestions MentorshipQuestion[]
  journeyNodes  UserJourneyNode[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Church {
  id          String   @id @default(uuid())
  name        String
  location    String?
  inviteCode  String?  @unique
  users       User[]
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  churchId    String?
  users       UserGroup[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserGroup {
  userId      String
  groupId     String
  user        User     @relation(fields: [userId], references: [id])
  group       Group    @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

model DailyJourney {
  id          String   @id @default(uuid())
  date        DateTime @unique
  verse       String
  verseRef    String
  reflection  String
  prayer      String
  missionId   String?
  mission     Mission? @relation(fields: [missionId], references: [id])
  quizId      String?
  quiz        Quiz?    @relation(fields: [quizId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Mission {
  id            String   @id @default(uuid())
  title         String
  description   String
  xpReward      Int      @default(50)
  dailyJourneys DailyJourney[]
  createdAt     DateTime @default(now())
}

model Quiz {
  id            String   @id @default(uuid())
  title         String
  description   String?
  type          String   // e.g., DAILY, WEEKLY, TOPIC
  xpReward      Int      @default(100)
  questions     Question[]
  attempts      QuizAttempt[]
  dailyJourneys DailyJourney[]
  createdAt     DateTime @default(now())
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  text          String
  type          String   // e.g., MCQ, TRUE_FALSE
  explanation   String?
  verse         String?
  answers       Answer[]
}

model Answer {
  id            String   @id @default(uuid())
  questionId    String
  question      Question @relation(fields: [questionId], references: [id])
  text          String
  isCorrect     Boolean  @default(false)
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  score       Int
  completedAt DateTime @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String?
  churchId    String?
  church      Church?  @relation(fields: [churchId], references: [id])
  attendances Attendance[]
  photos      EventGalleryPhoto[]
  createdAt   DateTime @default(now())
}

model EventGalleryPhoto {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  uploadedById String?
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model Attendance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  reflection  String?
  checkedInAt DateTime @default(now())
}

model PrayerCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  color       String?
  requests    PrayerRequest[]
}

model PrayerRequest {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  categoryId  String?
  category    PrayerCategory? @relation(fields: [categoryId], references: [id])
  content     String
  isAnonymous Boolean  @default(false)
  isApproved  Boolean  @default(false)
  prayCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String
  imageUrl    String?
  users       UserBadge[]
}

model UserBadge {
  userId      String
  badgeId     String
  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])
  awardedAt   DateTime @default(now())

  @@id([userId, badgeId])
}

model XPLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int
  reason      String   // e.g., "DAILY_JOURNEY", "EVENT_ATTENDANCE"
  awardedAt   DateTime @default(now())
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  targetRole  String?    // null means everyone
  createdAt   DateTime @default(now())
}

model SaintOfTheDay {
  id          String   @id @default(uuid())
  date        DateTime @unique
  name        String
  title       String?
  bio         String
  imageUrl    String?
}

model ReadingPlan {
  id          String   @id @default(uuid())
  title       String
  duration    String
  progress    Int      @default(0)
  icon        String
  color       String
}

model FeaturedVerse {
  id          String   @id @default(uuid())
  text        String
  reference   String
  theme       String
}

model JourneyCourse {
  id          String   @id @default(uuid())
  title       String
  description String
  color       String
  icon        String
  nodes       JourneyNode[]
  createdAt   DateTime @default(now())
}

model JourneyNode {
  id          String   @id @default(uuid())
  courseId    String
  course      JourneyCourse @relation(fields: [courseId], references: [id])
  title       String
  type        String   // "read", "quiz", "boss"
  content     String
  order       Int
  users       UserJourneyNode[]
}

model UserJourneyNode {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  nodeId      String
  node        JourneyNode @relation(fields: [nodeId], references: [id])
  status      String   // "completed", "current", "locked"
  stars       Int      @default(0) // 1-3 stars
  completedAt DateTime?

  @@unique([userId, nodeId])
}

model Guide {
  id          String   @id @default(uuid())
  title       String
  type        String   // e.g. "PRAYER", "EXAMINATION"
  content     String   // Can store JSON or text
  icon        String?
}

model Appointment {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  date        String
  time        String
  purpose     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model PushSubscription {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  endpoint    String   @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model MentorshipQuestion {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  text        String
  answer      String?
  answeredBy  String?
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
}
